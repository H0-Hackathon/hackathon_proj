# CoastGuard — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit the .env file to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Option A — SQLite (local dev, no setup)
DATABASE_URL=sqlite:///./coastguard.db

# Option B — Aurora PostgreSQL with a static password
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@YOUR_CLUSTER_ENDPOINT:5432/postgres

# Option C — Aurora PostgreSQL with IAM Authentication (recommended for AWS)
# Set AURORA_USE_IAM_AUTH=true and fill in the AURORA_* vars below.
# Leave DATABASE_URL as sqlite (it is ignored when IAM auth is enabled).
AURORA_USE_IAM_AUTH=false
AURORA_HOST=database-1.cluster-c10qouuuy62z.ap-south-1.rds.amazonaws.com
AURORA_PORT=5432
AURORA_USER=postgres
AURORA_DB=postgres
AURORA_REGION=ap-south-1

# AWS credentials for IAM token generation.
# If running on EC2 / ECS / Lambda with an IAM role attached, leave these blank —
# boto3 will pick up the instance/task role automatically.
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_SESSION_TOKEN=your_session_token_if_using_temporary_credentials

# ── Gemini API ────────────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
# Once set, also set USE_MOCK_LLM=false to enable real agent calls.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model — gemini-flash-latest is a Google-maintained alias that always
# points at the current flash-tier model (fast/cheap). Use gemini-pro-latest
# for higher quality.
GEMINI_MODEL=gemini/gemini-flash-latest

# ── Mock mode ─────────────────────────────────────────────────────────────────
# Phase 1: both true (no real LLM or API calls)
# Phase 2: set USE_MOCK_LLM=false after adding GEMINI_API_KEY
USE_MOCK_LLM=true
USE_MOCK_DATA=true

# When true, the TariffMonitor agent calls the real GDELT news API (free, no
# key needed) to ground its output in real headlines. Independent of
# USE_MOCK_LLM — combine real tools with mocked LLM reasoning if you want.
USE_REAL_TOOLS=false

# When true, a background job re-runs the monitor pipeline for every customer
# every SCHEDULER_INTERVAL_HOURS. Leave false for live demos — trigger runs
# manually with the "Run Monitor" button instead.
ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_HOURS=6

# ── External data sources (Phase 2+) ─────────────────────────────────────────
# GDELT needs no key — it's free and keyless (kept here for reference only).
USITC_API_KEY=your_usitc_key_here
GDELT_API_KEY=your_gdelt_key_here
SENTINELHUB_API_KEY=your_sentinelhub_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
CLERK_ISSUER_URL=your_clerk_issuer_url
ADMIN_WHITELIST=your_email@example.com

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=true
